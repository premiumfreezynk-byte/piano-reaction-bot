<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="28dp"
    android:background="#0D0D0D">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🎹 Piano Reaction Bot"
        android:textSize="26sp"
        android:textStyle="bold"
        android:textColor="#FFFFFF"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Sub-millisecond tile detection"
        android:textSize="13sp"
        android:textColor="#888888"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#CCCCCC"
        android:fontFamily="monospace"
        android:background="#1A1A1A"
        android:padding="16dp"
        android:layout_marginBottom="28dp"
        android:lineSpacingExtra="4dp" />

    <Button
        android:id="@+id/btnLaunch"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="LAUNCH BOT"
        android:textSize="15sp"
        android:textStyle="bold"
        android:backgroundTint="#1565C0"
        android:textColor="#FFFFFF" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="After launching: enable Accessibility Service in\nSettings › Accessibility › Installed Apps › Reaction Bot"
        android:textSize="11sp"
        android:textColor="#666666"
        android:gravity="center"
        android:layout_marginTop="20dp"
        android:lineSpacingExtra="3dp" />
</LinearLayout>
